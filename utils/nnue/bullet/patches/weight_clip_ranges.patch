+#[cfg(test)]
+mod tests {
+    use std::sync::Arc;
+
+    use crate::device::cpu::CpuThread;
+
+    use super::DenseMatrix;
+
+    #[test]
+    fn clamp_range_leaves_values_outside_the_range_unchanged() {
+        let mut matrix = DenseMatrix::<CpuThread>::zeroed(Arc::new(CpuThread), 7, None).unwrap();
+        matrix.load_from_slice(None, &[-2.0, -1.0, -0.4, 0.0, 0.4, 1.0, 2.0]).unwrap();
+
+        let min = i8::MIN as f32 / 255.0;
+        let max = i8::MAX as f32 / 255.0;
+        matrix.clamp_range(1, 5, min, max).unwrap();
+
+        let mut values = [0.0; 7];
+        matrix.write_to_slice(&mut values).unwrap();
+        assert_eq!(values, [-2.0, min, -0.4, 0.0, 0.4, max, 2.0]);
+        assert!(matrix.clamp_range(6, 2, min, max).is_err());
+    }
+}
