      "test_confidence": "[0.05, 0.05]",
      "win_adj": "movecount=3 score=400",
      "draw_adj": "movenumber=40 movecount=8 score=10"
    },
    "STC": {
      "both_options": "Threads=1 Hash=16",
      "both_time_control": "10.0+0.10",
      "workload_size": 32
