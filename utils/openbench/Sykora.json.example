    "LTC": {
      "both_options": "Threads=1 Hash=64",
      "both_time_control": "60.0+0.60",
      "workload_size": 8,
      "upload_pgns": "COMPACT"
    }
  },
  "tune_presets": {
    "default": {
      "book_name": "UHO_4060_v2.epd",
      "win_adj": "movecount=3 score=400",
      "draw_adj": "movenumber=40 movecount=8 score=10",
      "spsa_reporting_type": "BATCHED",
